# ========== DATABASE CONFIGURATION ==========
# MySQL Database Details
# IMPORTANTE: Non usare 'root' in produzione! Crea un utente dedicato.
DB_HOST=localhost
DB_USER=your_database_user
DB_PASS=your_secure_password
DB_NAME=luxury_hotel
DB_PORT=3306

# ========== EMAIL CONFIGURATION ==========
# For email notifications using mail() function
MAIL_FROM=info@luxuryhotel.it
MAIL_FROM_NAME=Luxury Hotel

# ========== DEBUG MODE ==========
# Set to true for development, false for production
# WARNING: Never enable DEBUG in production - it exposes sensitive error information
DEBUG=false

# ========== SECURITY CONFIGURATION ==========
# Lista di proxy fidati (IP o CIDR separati da virgola)
# Gli header X-Forwarded-For vengono accettati SOLO da questi IP
# Esempi:
# - Cloudflare: 173.245.48.0/20,103.21.244.0/22,103.22.200.0/22,103.31.4.0/22,...
# - Proxy locale: 127.0.0.1,10.0.0.0/8
# - Load balancer AWS: 10.0.0.0/8
# IMPORTANTE: Lasciare vuoto se non usi proxy/CDN (più sicuro)
TRUSTED_PROXIES=

# ========== WEBHOOK CONFIGURATION ==========
# Segreto condiviso per validare webhook dai payment provider
# OBBLIGATORIO per ricevere webhook di pagamento
# Genera con: php -r "echo bin2hex(random_bytes(32));"
# IMPORTANTE: Deve corrispondere al segreto configurato nel pannello del provider
WEBHOOK_SECRET=
