# ========== DATABASE CONFIGURATION ==========
# MySQL Database Details
# IMPORTANTE: Non usare 'root' in produzione! Crea un utente dedicato.
DB_HOST=localhost
DB_USER=your_database_user
DB_PASS=your_secure_password
DB_NAME=luxury_hotel
DB_PORT=3306

# ========== EMAIL CONFIGURATION ==========
# For email notifications using mail() function
MAIL_FROM=info@luxuryhotel.it
MAIL_FROM_NAME=Luxury Hotel

# ========== DEBUG MODE ==========
# Set to true for development, false for production
# WARNING: Never enable DEBUG in production - it exposes sensitive error information
DEBUG=false
